# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no Git — adicione-o ao .gitignore

DB_NAME=getgym_db
DB_USER=postgres
DB_PASSWORD=theu1
DB_HOST=localhost
DB_PORT=5432

# Chave secreta para assinar os JWTs (admin + financeiro)
JWT_SECRET_KEY=1aad9420c98f8fa30ebae88cc8079b188f943c631e974f4fbe2a600ce9e0db59

# Em produção, coloque a URL do seu frontend (sem barra no final)
